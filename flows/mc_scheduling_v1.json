{
  "version": "7.0",
  "screens": [
    {
      "id": "MODE",
      "title": "Pick contact mode",
      "data": {},
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "How would you like to be contacted?"
          },
          {
            "type": "RadioButtonsGroup",
            "name": "mode",
            "label": "Contact mode",
            "required": true,
            "data-source": [
              { "id": "text",     "title": "Text on WhatsApp" },
              { "id": "call",     "title": "Phone call" },
              { "id": "zoom",     "title": "Zoom call" },
              { "id": "facetime", "title": "FaceTime" },
              { "id": "wa_video", "title": "WhatsApp video call" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "DATE" },
              "payload": { "mode": "${form.mode}" }
            }
          }
        ]
      }
    },
    {
      "id": "DATE",
      "title": "Pick a date",
      "data": { "mode": { "type": "string", "__example__": "call" } },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "When should we reach you?"
          },
          {
            "type": "DatePicker",
            "name": "date",
            "label": "Date",
            "required": true,
            "min-date": "today",
            "max-date": "+15d"
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "TIME" },
              "payload": {
                "mode": "${data.mode}",
                "date": "${form.date}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "TIME",
      "title": "Pick a time",
      "data": {
        "mode": { "type": "string", "__example__": "call" },
        "date": { "type": "string", "__example__": "2026-04-29" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Pick a 30-min slot (11 AM – 9 PM IST)"
          },
          {
            "type": "Dropdown",
            "name": "time",
            "label": "Time slot (IST)",
            "required": true,
            "data-source": [
              { "id": "11:00", "title": "11:00 AM" }, { "id": "11:30", "title": "11:30 AM" },
              { "id": "12:00", "title": "12:00 PM" }, { "id": "12:30", "title": "12:30 PM" },
              { "id": "13:00", "title": "01:00 PM" }, { "id": "13:30", "title": "01:30 PM" },
              { "id": "14:00", "title": "02:00 PM" }, { "id": "14:30", "title": "02:30 PM" },
              { "id": "15:00", "title": "03:00 PM" }, { "id": "15:30", "title": "03:30 PM" },
              { "id": "16:00", "title": "04:00 PM" }, { "id": "16:30", "title": "04:30 PM" },
              { "id": "17:00", "title": "05:00 PM" }, { "id": "17:30", "title": "05:30 PM" },
              { "id": "18:00", "title": "06:00 PM" }, { "id": "18:30", "title": "06:30 PM" },
              { "id": "19:00", "title": "07:00 PM" }, { "id": "19:30", "title": "07:30 PM" },
              { "id": "20:00", "title": "08:00 PM" }, { "id": "20:30", "title": "08:30 PM" }
            ]
          },
          {
            "type": "Footer",
            "label": "Continue",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "NOTES" },
              "payload": {
                "mode": "${data.mode}",
                "date": "${data.date}",
                "time": "${form.time}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "NOTES",
      "title": "Anything else?",
      "terminal": true,
      "data": {
        "mode": { "type": "string", "__example__": "call" },
        "date": { "type": "string", "__example__": "2026-04-29" },
        "time": { "type": "string", "__example__": "14:30" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Anything we should know before our chat? (optional)"
          },
          {
            "type": "TextArea",
            "name": "notes",
            "label": "Notes",
            "required": false,
            "max-length": 500
          },
          {
            "type": "Footer",
            "label": "Confirm",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "mode":  "${data.mode}",
                "date":  "${data.date}",
                "time":  "${data.time}",
                "notes": "${form.notes}"
              }
            }
          }
        ]
      }
    }
  ]
}
